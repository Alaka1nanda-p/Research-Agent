# IBM Watsonx.ai Credentials
IBM_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# Granite Model Configuration
GRANITE_MODEL_ID=ibm/granite-8b-code-instruct
GRANITE_MAX_NEW_TOKENS_DEFAULT=300

# Token Usage Limits (approximate, for UI warning)
MAX_TOKENS_PER_DAY=50000
MAX_TOKENS_PER_SESSION=10000

# Flask Configuration
FLASK_SECRET_KEY=change-this-to-a-random-secret-string
FLASK_DEBUG=False

# Database
DATABASE_PATH=research_agent.db

# Search Configuration
MAX_PAPERS_PER_SEARCH=5
ABSTRACT_MAX_CHARS=1000
